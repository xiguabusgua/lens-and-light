# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=lens_light

# JWT 密钥（部署时请务必替换为随机字符串，openssl rand -hex 32）
JWT_SECRET=your-random-secret-here

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 服务端口（可选，默认 3002）
PORT=3002

# 运行环境
NODE_ENV=production

# CORS 允许的来源，多个用逗号分隔
# 部署时替换为你的域名，例如 https://example.com
CORS_ORIGIN=http://localhost:5173
